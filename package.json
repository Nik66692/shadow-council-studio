{
  "name": "shadow-council-studio",
  "version": "0.0.0-sprint.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": "22.17.0",
    "pnpm": "10.13.1"
  },
  "scripts": {
    "dev": "pnpm desktop:dev",
    "desktop:dev": "pnpm --filter @shadow-council/desktop dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --write .",
    "format:check": "prettier --check . && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml -- --check",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:all": "pnpm test && pnpm test:rust",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:rust && cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets -- -D warnings && pnpm canon:manifest:dry-run && pnpm supabase:schema:check",
    "canon:manifest": "pnpm --filter @shadow-council/canon-import manifest",
    "canon:manifest:dry-run": "pnpm --filter @shadow-council/canon-import manifest:dry-run",
    "supabase:schema:check": "node scripts/validate-supabase-schema.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "24.0.14",
    "eslint": "9.31.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0",
    "vitest": "3.2.4"
  }
}
